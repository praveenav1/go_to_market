# Flask Environment
FLASK_ENV=development
FLASK_PORT=5000

# Azure Blob Storage Configuration
# Optional: Generate a connection string from Azure Portal: Storage Account > Access Keys
AZURE_STORAGE_CONNECTION_STRING=

# Blob Storage Container Name
AZURE_STORAGE_CONTAINER_NAME=gtm-repo

# Primary blob container URL used by the API to build demo video links
AZURE_BLOB_CONTAINER_URL=https://skillsyncaistorage.blob.core.windows.net/gtm-repo

# Container-level SAS token without the leading '?'
AZURE_BLOB_SAS_TOKEN=sp=racwdli&st=2026-05-18T10:39:39Z&se=2099-05-18T18:54:39Z&sv=2025-11-05&sr=c&sig=SNBx1CCcWFWaw9M3zl8g%2FvWD7oL1cxYKQcqEvowwmBA%3D

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Application Settings
APP_DEBUG=True
